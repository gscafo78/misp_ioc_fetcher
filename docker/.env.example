# Sample environment file for MISP IOC Fetcher
# Copy this file to .env and fill in your actual values

# MISP API Key - Obtain from your MISP instance
MISP_APY_KEY=your_misp_api_key_here

# MISP Base URL
MISP_URL=https://your-misp-instance.com

# Verify SSL certificates (true/false)
MISP_VERIFY_CERT=false

# Optional: Custom output file paths (defaults are relative to script directory)
# OUTPUT_IP_FILE=ioc/ioc_ips.txt
# OUTPUT_URLS_FILE=ioc/ioc_urls.txt
# OUTPUT_HASHES_FILE=ioc/ioc_hashes.txt

# Update interval in seconds (0 = run once)
UPDATE_TIME=300